{
  "version": 2,
  "builds": [
    {
      "src": "api/quote.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/quote",
      "dest": "/api/quote.py"
    },
    {
      "src": "/api/search",
      "dest": "/api/quote.py"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
